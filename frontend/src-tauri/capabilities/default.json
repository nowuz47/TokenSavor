{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default Scrooge desktop permissions",
  "windows": ["main"],
  "permissions": [
    "shell:default",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "binaries/scrooge-backend",
          "sidecar": true
        }
      ]
    }
  ]
}
